    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "wavesurfer.js": "7.11.1",
    "zod": "^3.24.2"
