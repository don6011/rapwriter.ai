{
  "name": "rapwriter-ai",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "node --use-system-ca ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "node --use-system-ca ./node_modules/next/dist/bin/next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit --pretty false",
    "test:unit": "bun test src/lib",
    "test:e2e": "playwright test",
    "test:ci": "bun run lint && bun run typecheck && bun run test:unit && bun run test:e2e && bun run build",
    "test:access": "bun test src/lib/access-control.test.mjs",
    "test:lifecycle": "node --use-system-ca --env-file=.env.local scripts/test-auth-lifecycle.mjs",
    "test:producer": "bun test src/lib/producer-actions.test.mjs",
    "test:release": "bun test src/lib/producer-release.test.mjs",
    "test:production": "bun run test:unit && bun run test:lifecycle",
    "import:starter-beat": "node --use-system-ca --env-file=.env.local scripts/import-starter-beat.mjs",
    "sync:membership-plans": "node --use-system-ca --env-file=.env.local scripts/sync-prep-studio-plans.mjs",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@lovable.dev/cloud-auth-js": "^1.1.2",
